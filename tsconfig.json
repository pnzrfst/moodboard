{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler", 
    "outDir": "./dist",
    "rootDir": "./",            

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "verbatimModuleSyntax": true, 
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["*.ts"],         
  "exclude": ["node_modules", "dist"] 
}